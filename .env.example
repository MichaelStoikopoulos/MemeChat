# Discord application (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback

# Public base URL of this server (used to build invite/join links).
# Set this to your real domain or IP once it's not just running on your own machine.
PUBLIC_URL=http://localhost:3000

# Random long string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

PORT=3000

# Optional. Directory where data.sqlite is stored. Leave unset for local dev
# (defaults to the project root). On a host with an ephemeral filesystem
# (e.g. Railway), point this at a mounted persistent volume so the database
# survives redeploys, e.g. DATA_DIR=/data
DATA_DIR=

# Optional. Direct download URL for the desktop app installer (e.g. a
# GitHub release asset URL). If unset, /download/desktop-app falls back to
# serving whatever's in desktop-client/dist/ on the local filesystem.
DESKTOP_APP_DOWNLOAD_URL=
