{
  "name": "memechat-desktop",
  "version": "2.0.0",
  "private": true,
  "description": "MemeChat desktop overlay",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.memechat.desktop",
    "productName": "MemeChat",
    "files": ["**/*", "!dist/**"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
